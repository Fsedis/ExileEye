<ui:FluentWindow x:Class="ExileEye.PriceCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Price check"
        Width="480" SizeToContent="Height" MaxHeight="760"
        WindowStartupLocation="Manual"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Topmost="True" ShowInTaskbar="False"
        WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Price check" Icon="{x:Null}"/>

        <!-- Item + estimate -->
        <StackPanel Grid.Row="1" Margin="16,4,16,4">
            <TextBlock x:Name="ItemLabel" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock x:Name="EstimateText" FontSize="15" FontWeight="SemiBold" Margin="0,2,0,0"
                       Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" Text="Searching…"/>
            <TextBlock x:Name="RangeText" FontSize="12" Opacity="0.6"/>
        </StackPanel>

        <!-- Mods -->
        <ScrollViewer Grid.Row="2" MaxHeight="220" Margin="8,2,8,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ModList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding Include, Mode=TwoWay}"
                                      Click="OnControlChanged" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap"
                                       VerticalAlignment="Center" Opacity="0.9" FontSize="12"/>
                            <ui:TextBox Grid.Column="2" Text="{Binding MinText, Mode=TwoWay}"
                                        Width="52" Margin="8,0,0,0" PlaceholderText="min" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Inline search controls, right above the results (like the reference tools) -->
        <Grid Grid.Row="3" Margin="14,6,14,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" x:Name="StatusBox" Margin="2,0" SelectionChanged="OnControlChanged" ToolTip="Market"/>
            <ComboBox Grid.Column="1" x:Name="ListedBox" Margin="2,0" SelectionChanged="OnControlChanged" ToolTip="Listed within"/>
            <ComboBox Grid.Column="2" x:Name="CurrencyBox" Margin="2,0" SelectionChanged="OnControlChanged" ToolTip="Valuation currency"/>
        </Grid>

        <!-- Listings table -->
        <ScrollViewer Grid.Row="4" MaxHeight="260" Margin="8,6,8,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ListingList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Price}" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="{Binding Level}" Opacity="0.5" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="{Binding Quality}" Opacity="0.5" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="{Binding Account}" Opacity="0.55" TextTrimming="CharacterEllipsis" FontSize="12"/>
                            <TextBlock Grid.Column="4" Text="{Binding Age}" Opacity="0.4" FontSize="11"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="16,8,16,16">
            <ui:Button x:Name="SearchButton" Content="Search" Icon="{ui:SymbolIcon Search24}"
                       Appearance="Primary" Click="OnSearch"/>
            <ui:Button x:Name="BrowserButton" Content="Open in browser" Icon="{ui:SymbolIcon Open24}"
                       Margin="8,0,0,0" Click="OnOpenBrowser" IsEnabled="False"/>
            <TextBlock x:Name="StatusLine" VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.5" FontSize="12"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
