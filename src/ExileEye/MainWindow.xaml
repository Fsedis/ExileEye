<ui:FluentWindow x:Class="ExileEye.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ExileEye"
        Width="520" Height="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Closing="OnClosing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="ExileEye" Icon="{x:Null}" />

        <StackPanel Grid.Row="1" Margin="20,8,20,20">

            <StackPanel Orientation="Horizontal" Margin="4,0,0,14">
                <ui:SymbolIcon Symbol="Eye24" FontSize="26" VerticalAlignment="Center"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="ExileEye" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Live poe.ninja prices over your game panel" Opacity="0.55" FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <ui:Card Margin="0,0,0,10" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Game language" VerticalAlignment="Center" Opacity="0.8"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="LanguageBox" Margin="0,2"
                              SelectionChanged="OnLanguageChanged"
                              ToolTip="Language your PoE2 client runs in — item names are read in it"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="League" VerticalAlignment="Center" Opacity="0.8"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="LeagueBox" Margin="0,2"
                              SelectionChanged="OnLeagueChanged"/>
                </Grid>
            </ui:Card>

            <ui:Card Margin="0,0,0,10" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Price check" VerticalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PriceHotkeyText" Text="Ctrl+D"
                               VerticalAlignment="Center" FontFamily="Consolas" Opacity="0.7"/>
                    <ui:Button Grid.Row="0" Grid.Column="2" Content="Rebind" Click="OnRebindPrice" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Scan panel" VerticalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ScanHotkeyText" Text="Ctrl+S"
                               VerticalAlignment="Center" FontFamily="Consolas" Opacity="0.7"/>
                    <ui:Button Grid.Row="1" Grid.Column="2" Content="Rebind" Click="OnRebindScan"/>
                </Grid>
            </ui:Card>

            <ui:Card Margin="0,0,0,10" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Listings" VerticalAlignment="Center" Opacity="0.8"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="StatusBox" Margin="0,2"
                              SelectionChanged="OnTradeOptionChanged"
                              ToolTip="Trade market: Instant buyout = securable (buy now), Online = personal trade (whisper the seller)."/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Listed within" VerticalAlignment="Center" Opacity="0.8"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ListedBox" Margin="0,2"
                              SelectionChanged="OnTradeOptionChanged"
                              ToolTip="Only listings posted within this window — fresher listings are more likely buyable now."/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="POESESSID" VerticalAlignment="Center" Opacity="0.8"/>
                    <ui:TextBox Grid.Row="2" Grid.Column="1" x:Name="SessionBox" Margin="0,2"
                                PlaceholderText="paste your session cookie"
                                LostFocus="OnSessionChanged"
                                ToolTip="From pathofexile.com browser cookies (F12 → Application → Cookies → POESESSID). Needed for the instant-buyout market. Stored locally."/>
                </Grid>
            </ui:Card>

            <ui:InfoBar x:Name="StatusBar" IsOpen="True" IsClosable="False"
                        Severity="Informational" Title="Starting" Message="Loading prices from poe.ninja…"/>

            <TextBlock x:Name="VersionLabel" Opacity="0.4" FontSize="11" Margin="4,10,0,0"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
