<ui:FluentWindow x:Class="ExileEye.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ExileEye"
        Width="560" Height="420"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="ExileEye" Icon="{x:Null}" />

        <StackPanel Grid.Row="1" Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center">
            <ui:SymbolIcon Symbol="Eye24" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="ExileEye" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="On-screen price checker for Path of Exile 2"
                       Opacity="0.6" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <TextBlock Text="Скоро здесь будет мастер первого запуска"
                       Opacity="0.4" FontSize="12" HorizontalAlignment="Center" Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
